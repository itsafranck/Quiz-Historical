rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny catch-all
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper: Check if user is the known owner/admin
    function isAdmin() {
      return request.auth != null && request.auth.token.email == 'francklloydsomoza1@gmail.com' && request.auth.token.email_verified == true;
    }

    // Helper: ID validation
    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // Validation Blueprint for QuizSubmission
    function isValidQuizSubmission(data) {
      return data.userName is string && data.userName.size() > 0 && data.userName.size() <= 100
          && data.score is number && data.score >= 0 && data.score <= data.totalQuestions
          && data.totalQuestions is number && data.totalQuestions > 0
          && data.answers is list && data.answers.size() > 0 && data.answers.size() <= 50
          && data.submittedAt == request.time;
    }

    match /submissions/{submissionId} {
      // Allow anyone to submit a result, but enforce strict schema
      allow create: if isValidQuizSubmission(request.resource.data);
      
      // Only the admin can read all submissions
      allow get, list: if isAdmin();
      
      // No one can update or delete records (immutability)
      allow update, delete: if false;
    }
  }
}
